{
  "name": "asel-butik",
  "version": "1.2.7",
  "description": "برنامج متكامل لبوتيك أزياء نسائية فاخرة، يتكون من واجهتين متصلتين بقاعدة بيانات سحابية متزامنة على **سوبابيس (Supabase)**.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "dev": "npx -y http-server -p 3000 . -o",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/latrecheyasser1-hue/asel-butik.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/latrecheyasser1-hue/asel-butik/issues"
  },
  "homepage": "https://github.com/latrecheyasser1-hue/asel-butik#readme",
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "pg": "^8.21.0",
    "playwright": "^1.61.0"
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.aselbutik.pos",
    "productName": "Asel Butik",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!_site/**/*",
      "!dist/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "dist/.icon-ico/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
